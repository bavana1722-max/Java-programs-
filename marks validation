import java.io.File;
import java.io.FileReader;
public class MockValidation {
static void validateMark(int mark) throws Exception {
if (mark < 0 || mark > 100) {
throw new Exception("Invalid Mark! Mark should be between 0 and 100");
} else {
System.out.println("Valid Mark : " + mark);
}
}
public static void main(String[] args) {
try {
int mockMark = 120;   
validateMark(mockMark);
} catch (Exception e) {
System.out.println("Mock Error : " + e.getMessage());
}
try {
int a = 10, b = 0;
int c = a / b;
System.out.println("Result : " + c);
} catch (ArithmeticException e) {
System.out.println("Arithmetic Error : Division by zero");
}
try {
File file = new File("student.txt"); // file not available
FileReader fr = new FileReader(file);
System.out.println("File opened successfully");
} catch (Exception e) {
System.out.println("File Error : File not found");
}
System.out.println("Program executed successfully");
}
}
